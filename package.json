{
  "name": "idea-coding",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --test test/project-data-quality.test.mjs",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "data:discover": "node scripts/discover-topics.mjs",
    "data:evaluate": "node scripts/ai-evaluate.mjs",
    "data:validate": "node scripts/validate-data.mjs",
    "data:refresh": "node scripts/discover-topics.mjs && node scripts/ai-evaluate.mjs && node scripts/validate-data.mjs"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.107.0"
  }
}
